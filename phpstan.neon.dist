# Runs at level 5 (real type-safety: undefined methods/properties, bad
# arguments, dead code) — clean. Level `max` is a deferred hardening pass: it
# currently surfaces ~220 findings dominated by larastan's migration-inference
# emitting imprecise nonObject/cast types on Eloquent attribute + relation
# access (mostly false positives), needing per-model @property + relation
# generics to resolve. Tracked in docs/ROADMAP.md (Phase 3z).
includes:
    - vendor/larastan/larastan/extension.neon

parameters:
    level: 5
    paths:
        - src
        - tests/Fixtures
    # Let larastan infer Eloquent model attributes from the package schema, so
    # dynamic property access ($code->state, etc.) resolves without docblocks.
    databaseMigrationsPath:
        - database/migrations
    tmpDir: build/phpstan
