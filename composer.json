{
    "name": "padosoft/laravel-invitations",
    "description": "Enterprise invite-by-code, referral, rewards, waitlist & anti-abuse system for Laravel — multi-tenant, concurrency-safe, idempotent, GDPR-ready.",
    "keywords": [
        "laravel",
        "invitations",
        "invite",
        "invite-codes",
        "referral",
        "rewards",
        "waitlist",
        "multi-tenant",
        "growth",
        "k-factor"
    ],
    "homepage": "https://github.com/padosoft/laravel-invitations",
    "license": "MIT",
    "authors": [
        {
            "name": "Padosoft",
            "email": "support@padosoft.com",
            "homepage": "https://www.padosoft.com"
        }
    ],
    "require": {
        "php": "^8.3",
        "illuminate/contracts": "^12.0|^13.0",
        "illuminate/database": "^12.0|^13.0",
        "illuminate/support": "^12.0|^13.0",
        "spatie/laravel-package-tools": "^1.92"
    },
    "require-dev": {
        "larastan/larastan": "^3.0",
        "laravel/mcp": "^0.7|^0.8",
        "laravel/pint": "^1.18",
        "orchestra/testbench": "^10.0|^11.0",
        "phpunit/phpunit": "^11.5|^12.0",
        "spatie/laravel-permission": "^6.0"
    },
    "suggest": {
        "spatie/laravel-permission": "Enables the default SpatiePermissionProvisioner to grant roles on redemption.",
        "laravel/fortify": "Integrate the invite-gate with Fortify's registration pipeline.",
        "laravel/mcp": "Register the bundled MCP tools (InviteValidateCode, InviteGenerateCodes, InviteMetrics) on your MCP server."
    },
    "autoload": {
        "psr-4": {
            "Padosoft\\Invitations\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Padosoft\\Invitations\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "analyse": "vendor/bin/phpstan analyse",
        "format": "vendor/bin/pint",
        "test": "vendor/bin/phpunit",
        "check": [
            "@format",
            "@analyse",
            "@test"
        ]
    },
    "config": {
        "sort-packages": true,
        "platform": {
            "php": "8.3.0"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Padosoft\\Invitations\\InvitationsServiceProvider"
            ]
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
